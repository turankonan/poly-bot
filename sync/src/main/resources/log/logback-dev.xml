<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <appender name="RollingFile" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/log/sync.log</file>
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <Pattern>%d{ISO8601} %-5level [%t] [%X{contextLog}] %C{10}: %msg%n%throwable</Pattern>
        </encoder>

        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/log/sync-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <timeBasedFileNamingAndTriggeringPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedFNATP">
                <maxFileSize>500MB</maxFileSize>
            </timeBasedFileNamingAndTriggeringPolicy>
        </rollingPolicy>
    </appender>

    <root level="info">
        <appender-ref ref="RollingFile"/>
    </root>

    <logger name="polymarket.bot" level="trace" additivity="false">
        <appender-ref ref="RollingFile"/>
    </logger>

    <logger name="org.spring" level="info" additivity="false">
        <appender-ref ref="RollingFile"/>
    </logger>

    <logger name="org.springframework" level="info" additivity="false">
        <appender-ref ref="RollingFile"/>
    </logger>

</configuration>
