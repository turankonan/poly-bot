{
    // ── Java Runtime ──────────────────────────────────────────────────────
    "java.jdt.ls.java.home": "/Users/turankonan/Library/Java/JavaVirtualMachines/openjdk-23.0.1/Contents/Home",
    "java.configuration.runtimes": [
        {
            "name": "JavaSE-23",
            "path": "/Users/turankonan/Library/Java/JavaVirtualMachines/openjdk-23.0.1/Contents/Home",
            "default": true
        }
    ],
    // ── Maven ─────────────────────────────────────────────────────────────
    "java.configuration.maven.globalSettings": "",
    "maven.executable.preferMavenWrapper": true,
    "maven.terminal.useJavaHome": true,
    "maven.view": "hierarchical", // Multi-modül yapısı için hiyerarşik görünüm
    "java.maven.downloadSources": true, // Kaynak kodları indir (kütüphane içine geç)
    "java.maven.updateSnapshots": false,
    // ── Derleme & Proje ───────────────────────────────────────────────────
    "java.autobuild.enabled": true,
    "java.compile.nullAnalysis.mode": "automatic",
    "java.sources.organizeImports.starThreshold": 5,
    "java.sources.organizeImports.staticStarThreshold": 3,
    "java.completion.importOrder": [
        "java",
        "javax",
        "jakarta",
        "org",
        "com",
        "polymarket"
    ],
    "java.cleanup.actionsOnSave": [
        "organizeImports",
        "qualifyStaticMembers"
    ],
    // ── Test ──────────────────────────────────────────────────────────────
    "java.test.config": {
        "vmArgs": [
            "-Dspring.profiles.active=test"
        ]
    },
    // ── Spring Boot ───────────────────────────────────────────────────────
    "spring-boot.ls.java.home": "/Users/turankonan/Library/Java/JavaVirtualMachines/openjdk-23.0.1/Contents/Home",
    "spring-boot.ls.problem.application-properties.UNKNOWN_PROPERTY_KEY": "WARNING",
    // ── Editör ────────────────────────────────────────────────────────────
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.formatOnSave": true,
    "editor.formatOnType": false,
    "editor.codeActionsOnSave": {
        "source.organizeImports": "explicit",
        "source.fixAll": "explicit"
    },
    "editor.rulers": [
        120
    ], // Java satır uzunluğu sınırı
    "editor.suggest.snippetsPreventQuickSuggestions": false,
    "editor.inlayHints.enabled": "onUnlessPressed", // Tip hintsları Cmd basınca gizle
    // ── Dosya İlişkilendirmeleri ──────────────────────────────────────────
    "files.associations": {
        "*.yml": "yaml",
        "*.yaml": "yaml",
        "application*.yml": "spring-boot-properties-yaml",
        "application*.properties": "spring-boot-properties"
    },
    "files.exclude": {
        "**/.classpath": true,
        "**/.project": true,
        "**/.settings": true,
        "**/.factorypath": true,
        "**/__pycache__": true
    },
    "files.watcherExclude": {
        "**/target/**": true,
        "**/.git/objects/**": true
    },
    // ── YAML / OpenAPI ────────────────────────────────────────────────────
    "yaml.schemas": {
        "https://json.schemastore.org/spring-boot-application-2.7.json": [
            "src/main/resources/application*.yml",
            "src/main/resources/application*.yaml"
        ]
    },
    "[yaml]": {
        "editor.tabSize": 2,
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "[xml]": {
        "editor.defaultFormatter": "redhat.vscode-xml"
    },
    // ── Terminal ──────────────────────────────────────────────────────────
    "terminal.integrated.env.osx": {
        "JAVA_HOME": "/Users/turankonan/Library/Java/JavaVirtualMachines/openjdk-23.0.1/Contents/Home"
    },
    // ── Git ───────────────────────────────────────────────────────────────
    "git.autofetch": true,
    "gitlens.hovers.currentLine.over": "line",
    // ── SonarLint ─────────────────────────────────────────────────────────
    "sonarlint.rules": {
        "java:S106": {
            "level": "off"
        } // System.out.println — geliştirmede tamam
    },
    // ── İkonlar ───────────────────────────────────────────────────────────
    "workbench.iconTheme": "material-icon-theme",
    "material-icon-theme.folders.associations": {
        "sync": "sync",
        "rest-api": "api",
        "model": "class",
        "common": "shared",
        "repository": "database",
        "config": "config",
        "util": "tools",
        "service": "middleware"
    },
    "java.configuration.updateBuildConfiguration": "interactive"
}