{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "java",
            "name": "sync-run (local)",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "mainClass": "polymarket.bot.sync.SyncApplication",
            "projectName": "sync",
            "args": "--spring.profiles.active=local",
            "vmArgs": "-Dfile.encoding=UTF-8 -Dspring.devtools.restart.enabled=false",
            "console": "integratedTerminal"
        },
        {
            "type": "java",
            "name": "Attach to remote JVM (5005)",
            "request": "attach",
            "hostName": "localhost",
            "port": 5005
        }
    ]
}